# Copy this file to `.env` for local dev, and set the SAME variables in your
# Vercel project (Settings → Environment Variables) for deployment.
# NOTE: Vite inlines VITE_* vars at BUILD time — after changing them in Vercel
# you must trigger a new deployment for the change to take effect.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (a JWT starting with "eyJ")
VITE_SUPABASE_ANON_KEY=

# ImgBB API key — LOCAL DEVELOPMENT ONLY.
# In production this must NOT be set (a VITE_* var is baked into the public
# browser bundle). Production uploads go through /api/upload-image instead.
VITE_IMGBB_API_KEY=

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY (set these in Vercel → Settings → Environment Variables).
# They are never exposed to the browser.
# ---------------------------------------------------------------------------
# ImgBB key used by the /api/upload-image serverless proxy
IMGBB_API_KEY=

# The Supabase account email allowed to upload (must match your admin user)
ADMIN_EMAIL=
